import numpy as np
import matplotlib.pyplot as plt

Ac = float(input("Enter Carrier Amplitude: "))   #10
Am = float(input("Enter Message Amplitude: "))   #5
fc = float(input("Enter Carrier frequency: "))   #50
fm = float(input("Enter Message frequency: "))   #2

#β=Δf/fm   Δf=kf*Am
kf = float(input("Enter Frequency Sensitivity (kf): "))  # usually taken 1000, 5 lena
delta_f = kf * Am
beta = delta_f / fm

t = np.linspace(0,1,5000)

carrier = Ac*np.cos(2*np.pi*fc*t)
message = Am*np.cos(2*np.pi*fm*t)

FM_Signal = Ac*np.cos(2*np.pi*fc*t + beta*np.sin(2*np.pi*fm*t))

plt.figure(figsize=(12,8))

plt.subplot(3,1,1)
plt.plot(t,carrier)
plt.title("Carrier SIgnal c(t)")
plt.xlabel("Time(s)")
plt.ylabel("Amplitude")
plt.grid(True)

plt.subplot(3,1,2)
plt.plot(t,message)
plt.title("Message SIgnal c(t)")
plt.xlabel("Time(s)")
plt.ylabel("Amplitude")
plt.grid(True)

plt.subplot(3,1,3)
plt.plot(t,FM_Signal)
plt.title("FM modulated SIgnal c(t)")
plt.xlabel("Time(s)")
plt.ylabel("Amplitude")
plt.grid(True)

plt.tight_layout()
plt.show()


